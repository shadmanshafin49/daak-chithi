# Base URL of the Daak Chithi backend (no trailing slash).
#
# Local dev on a physical device: use your computer's LAN IP (find it with
# `ipconfig` on Windows / `ifconfig` on macOS), with the backend port (5000).
#   EXPO_PUBLIC_API_URL=http://192.168.0.106:5000
#
# Android emulator: http://10.0.2.2:5000   |   iOS simulator: http://localhost:5000
EXPO_PUBLIC_API_URL=http://192.168.0.106:5000
